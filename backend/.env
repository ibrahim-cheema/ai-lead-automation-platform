# ─── Business Identity ────────────────────────────────────────────────────────
# Set these to match the client whose website this tool is deployed on.
# The AI uses these to write follow-up emails AS this business, not as LeadNova AI.
BUSINESS_NAME=Heuristro
BUSINESS_TAGLINE=Software Development, Web Development & AI Automation
BUSINESS_SERVICES=custom software development, web application development, mobile app development, AI automation, workflow automation, API integrations, and digital transformation consulting
BUSINESS_CONTACT_NAME=The Heuristro Team
BUSINESS_CONTACT_EMAIL=hello@heuristro.com
# ──────────────────────────────────────────────────────────────────────────────

# Database Connection
# If left empty, the application will automatically fallback to local SQLite (backend/leads.db)
DATABASE_URL=

# AI Model Provider Configurations
# Supported values: openai, groq, huggingface, xai, mock
# If no keys are provided, it automatically falls back to "mock" for zero-config demo mode.
AI_PROVIDER=mock

# xAI (Grok) API config
XAI_API_KEY=xai-nmzKgp00MydgkoGdmp4kKgw96nLUjldSNIebhvkeyUefC9fij1lbSx1A9uJwVNKdfO3kQW4KFEGkGi76
XAI_MODEL=grok-2-latest

# OpenAI API config
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq API config
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# Hugging Face config
HF_API_KEY=
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
