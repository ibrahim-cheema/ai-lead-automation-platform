# ────────────────────────────────────────────────────────────────────────────────
# Lead Automation Platform — Environment Variables Reference
# Copy this file to .env and fill in your values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────────

# ── Business Identity ──────────────────────────────────────────────────────────
BUSINESS_NAME=Your Company Name
BUSINESS_TAGLINE=Your Tagline Here
BUSINESS_SERVICES=list your services here
BUSINESS_CONTACT_NAME=The Team
BUSINESS_CONTACT_EMAIL=hello@yourcompany.com

# ── Database ───────────────────────────────────────────────────────────────────
# Leave blank to use local SQLite (backend/leads.db).
# Set to a PostgreSQL URL for production: postgresql://user:pass@host/db
DATABASE_URL=

# ── AI Provider Selection ──────────────────────────────────────────────────────
# Which model generates lead analysis, email & SMS drafts.
# Options: gpt-oss | openai | groq | xai | hf | mock
AI_PROVIDER=gpt-oss

# ── GPT-OSS-120B (Primary — Hugging Face Inference API) ───────────────────────
# Model: openai/gpt-oss-120b  (https://huggingface.co/openai/gpt-oss-120b)
# Requires: HF_API_KEY with inference access
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GPTOSS_MODEL=openai/gpt-oss-120b
GPTOSS_TEMPERATURE=0.7
GPTOSS_MAX_TOKENS=1024

# ── Agent Orchestration (AI decision-making layer) ────────────────────────────
# Claude Haiku orchestrates the agent's tool-use loop.
# Leave blank to run in direct-tool mode (same MCP tools, no AI orchestration).
ANTHROPIC_API_KEY=

# ── OpenAI (optional fallback) ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Groq (optional fallback) ──────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# ── xAI Grok (optional fallback) ──────────────────────────────────────────────
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# ── Hugging Face generic (optional, if AI_PROVIDER=hf) ────────────────────────
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
